{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "prettier-fix": {},
    "lint": {},
    "test": {},
    "mobile#verify:contracts": {},
    "mobile#verify:migration": {},
    "verify:mobile": {
      "dependsOn": ["mobile#verify:migration", "mobile#verify:contracts"]
    },
    "dev": {
      "persistent": true,
      "cache": false
    }
  }
}
