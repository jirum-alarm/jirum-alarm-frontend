{
  "name": "mobile",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "expo run:android",
    "build:android:debug": "./android/gradlew -p android assembleDebug --console=plain",
    "build:android:release": "NODE_ENV=production ./android/gradlew -p android assembleRelease --console=plain -PreactNativeArchitectures=armeabi-v7a,arm64-v8a",
    "build-android:release": "pnpm run build:android:release",
    "build:ios:debug:sim": "rm -rf ios/build/debug-sim && xcodebuild -workspace ios/jirumAlarmMobile.xcworkspace -scheme jirumAlarmMobile -configuration Debug -destination 'generic/platform=iOS Simulator' build",
    "build:ios:release:sim": "rm -rf ios/build/release-sim && xcodebuild -workspace ios/jirumAlarmMobile.xcworkspace -scheme jirumAlarmMobile -configuration Release -destination 'generic/platform=iOS Simulator' build",
    "ios": "expo run:ios",
    "clean-ios": "cd ios && rm -rf build && pod cache clean --all && pod deintegrate && rm Podfile.lock && pod install",
    "clean-android": "./android/gradlew -p android --stop && rm -rf android/app/.cxx && ./android/gradlew -p android clean && rm -rf android/.gradle android/build android/app/build",
    "generate": "graphql-codegen",
    "check-types": "tsc --noEmit",
    "ts:check": "pnpm run check-types",
    "lint": "eslint App.tsx index.js src __tests__ babel.config.js metro.config.js react-native.config.js jest.config.js",
    "prettier-fix": "prettier --config .prettierrc.js --write \"./**/*.{js,jsx,ts,tsx,json}\" --ignore-path .gitignore --ignore-path .prettierignore",
    "verify:contracts": "node scripts/verify-public-contracts.mjs",
    "verify:migration": "pnpm generate && pnpm ts:check && pnpm lint && pnpm exec jest --runInBand && npx expo-doctor",
    "start": "expo start",
    "test": "jest",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.0.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.4.1",
    "@react-native-cookies/cookies": "6.2.1",
    "@react-native-firebase/app": "21.14.0",
    "@react-native-firebase/messaging": "21.14.0",
    "@react-native-masked-view/masked-view": "^0.3.2",
    "@react-native-seoul/kakao-login": "5.4.2",
    "@react-native-seoul/naver-login": "4.2.4",
    "@react-navigation/bottom-tabs": "7.15.5",
    "@react-navigation/native": "7.1.33",
    "@react-navigation/native-stack": "7.14.5",
    "@tanstack/react-query": "^5.66.0",
    "class-variance-authority": "^0.7.1",
    "expo": "~54.0.33",
    "expo-apple-authentication": "~8.0.8",
    "expo-dev-client": "~6.0.20",
    "expo-notifications": "^0.32.16",
    "expo-web-browser": "~15.0.10",
    "nativewind": "4.2.2",
    "react": "19.1.0",
    "react-hook-form": "^7.55.0",
    "react-native": "0.81.5",
    "react-native-bootsplash": "6.3.12",
    "react-native-edge-to-edge": "1.6.0",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-keyboard-controller": "1.18.5",
    "react-native-reanimated": "~4.1.6",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-toast-message": "^2.2.1",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1",
    "tailwind-merge": "^3.1.0",
    "tailwindcss": "^3.4.17",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@0no-co/graphqlsp": "^1.12.16",
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@graphql-codegen/cli": "^5.0.4",
    "@graphql-codegen/schema-ast": "^4.1.0",
    "@graphql-codegen/typed-document-node": "^5.0.13",
    "@parcel/watcher": "^2.5.1",
    "@react-native-community/cli": "20.0.0",
    "@react-native-community/cli-platform-android": "20.0.0",
    "@react-native-community/cli-platform-ios": "20.0.0",
    "@react-native/babel-preset": "0.81.5",
    "@react-native/eslint-config": "0.81.5",
    "@react-native/metro-config": "0.81.5",
    "@react-native/typescript-config": "0.81.5",
    "@types/jest": "^29.5.13",
    "@types/react": "~19.1.17",
    "@types/react-test-renderer": "^19.1.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "eslint": "^8.19.0",
    "expo-doctor": "1.13.5",
    "jest": "^29.6.3",
    "patch-package": "^8.0.1",
    "prettier": "2.8.8",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.3"
  },
  "expo": {
    "doctor": {
      "appConfigFieldsNotSyncedCheck": {
        "enabled": false
      },
      "reactNativeDirectoryCheck": {
        "exclude": [
          "@react-native-cookies/cookies"
        ],
        "listUnknownPackages": false
      }
    }
  }
}
