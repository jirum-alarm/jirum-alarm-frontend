# Copy to android/keystore.properties after restoring android/app/jirumalarmkey.jks.
# Source the placeholder values from MOBILE_ANDROID_KEYSTORE_PASSWORD,
# MOBILE_ANDROID_KEY_ALIAS, and MOBILE_ANDROID_KEY_PASSWORD.
storeFile=jirumalarmkey.jks
storePassword=__MOBILE_ANDROID_KEYSTORE_PASSWORD__
keyAlias=__MOBILE_ANDROID_KEY_ALIAS__
keyPassword=__MOBILE_ANDROID_KEY_PASSWORD__
