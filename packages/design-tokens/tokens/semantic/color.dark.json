{
  "_comment": "다크모드 시맨틱 매핑. 새 팔레트 없이 기존 gray 스케일을 '뒤집어' 명도 위계를 반전한다(관습적 다크). 원시 스케일(primitive/color.json)은 불변, 이 매핑만 .dark 블록으로 방출. brand/error/link 강조색은 라이트값 유지(다크에서도 강조). 키 구조는 semantic/color.json(라이트)과 1:1 대응 — 빌드가 .dark { --color-* } 로 override.",

  "dark": {
    "text": {
      "primary": { "$type": "color", "$value": "{color.gray.50}" },
      "secondary": { "$type": "color", "$value": "{color.gray.400}" },
      "tertiary": { "$type": "color", "$value": "{color.gray.500}" },
      "disabled": { "$type": "color", "$value": "{color.gray.600}" },
      "inverse": { "$type": "color", "$value": "{color.gray.900}" },
      "brand": { "$type": "color", "$value": "{color.primary.500}" },
      "error": { "$type": "color", "$value": "{color.error.400}" },
      "error-strong": { "$type": "color", "$value": "{color.error.300}" },
      "strong": { "$type": "color", "$value": "{color.gray.100}" },
      "secondary-strong": { "$type": "color", "$value": "{color.gray.200}" },
      "muted": { "$type": "color", "$value": "{color.gray.400}" },
      "link": { "$type": "color", "$value": "{color.link}" }
    },

    "surface": {
      "default": { "$type": "color", "$value": "{color.gray.900}" },
      "subtle": { "$type": "color", "$value": "{color.gray.800}" },
      "muted": { "$type": "color", "$value": "{color.gray.700}" },
      "brand": { "$type": "color", "$value": "{color.primary.500}" },
      "inverse": { "$type": "color", "$value": "{color.white}" },
      "inverse-strong": { "$type": "color", "$value": "{color.gray.100}" },
      "inverse-subtle": { "$type": "color", "$value": "{color.gray.200}" },
      "inverse-muted": { "$type": "color", "$value": "{color.gray.400}" },
      "emphasis": { "$type": "color", "$value": "{color.gray.700}" },
      "error": { "$type": "color", "$value": "{color.error.900}" },
      "disabled": { "$type": "color", "$value": "{color.gray.700}" },
      "disabled-strong": { "$type": "color", "$value": "{color.gray.600}" }
    },

    "border": {
      "default": { "$type": "color", "$value": "{color.gray.700}" },
      "strong": { "$type": "color", "$value": "{color.gray.600}" },
      "subtle": { "$type": "color", "$value": "{color.gray.800}" },
      "brand": { "$type": "color", "$value": "{color.primary.500}" },
      "interactive": { "$type": "color", "$value": "{color.gray.500}" },
      "focus": { "$type": "color", "$value": "{color.gray.100}" }
    }
  }
}
